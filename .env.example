# First-run admin bootstrap.
# Set these before the first server start so the app can create the initial admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Optional. Reserved for future session-signing/rotation needs.
# Current auth stores only a random server-side session token hash in SQLite.
SESSION_SECRET=replace-with-a-long-random-string

# Zhipu AI / Z.ai API key used by GLM-4.7-Flash server-side requests.
ZAI_API_KEY=replace-with-your-zai-api-key

# Required before users can save personal SiliconFlow API keys.
USER_API_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret
